# Template — do NOT commit real values.
# Generate with:
#   make create-claude-vertex-secret \
#     PROJECT_ID=<gcp-project-id> \
#     REGION=<region e.g. us-east5> \
#     CREDS_FILE=~/.config/gcloud/application_default_credentials.json
#
# CREDS_FILE is the ADC JSON from: gcloud auth application-default login
# The generated claude-vertex-secret.yaml is gitignored.
apiVersion: v1
kind: Secret
metadata:
  name: claude-vertex-secret
type: Opaque
data:
  ANTHROPIC_VERTEX_PROJECT_ID: <base64-encoded-project-id>
  CLOUD_ML_REGION: <base64-encoded-region>
  application_default_credentials.json: <base64-encoded-adc-json>
