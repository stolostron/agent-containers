# Template — do NOT commit real values.
# Generate github-secret.yaml from an SSH private key:
#
#   ./scripts/create-secrets.sh github ~/.ssh/id_rsa
#
# Or apply a pre-built secret:
#   kubectl apply -f k8s/secrets/github-secret.yaml
#
# The generated github-secret.yaml is gitignored.
apiVersion: v1
kind: Secret
metadata:
  name: github-secret
type: Opaque
data:
  ssh_private_key: <base64-encoded-ssh-private-key>
