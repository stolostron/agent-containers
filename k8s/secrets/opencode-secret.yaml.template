# Fill in your values below, then run: make create-opencode-secret
# Copy this file to opencode-secret.yaml (which is gitignored).
#
# CREDS_FILE: path to GCP ADC JSON from: gcloud auth application-default login
#             defaults to ~/.config/gcloud/application_default_credentials.json
apiVersion: v1
kind: Secret
metadata:
  name: opencode-secret
type: Opaque
stringData:
  GOOGLE_CLOUD_PROJECT: ""
  VERTEX_LOCATION: ""
  GOOGLE_API_KEY: ""
  GITHUB_PAT: ""
