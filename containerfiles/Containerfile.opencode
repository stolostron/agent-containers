ARG LANG=golang

# ---- Base: node + common tools + opencode ----
FROM node:20-slim AS base-common

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates zsh fzf vim nano less jq ripgrep \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# npm global prefix under /usr/local/share, owned by the non-root "node" user
# (the "node" user already exists in the base image)
RUN mkdir -p /usr/local/share/npm-global \
    && chown -R node:node /usr/local/share/npm-global
ENV NPM_CONFIG_PREFIX=/usr/local/share/npm-global
ENV PATH=$PATH:/usr/local/share/npm-global/bin

USER node
RUN npm install -g opencode-ai && npm cache clean --force
WORKDIR /workspace

ENV DEVCONTAINER=true
ENV EDITOR=nano
ENV NODE_OPTIONS=--max-old-space-size=4096

# Provider config: restrict to Claude (Vertex) and Gemini only.
# Credentials are injected at runtime via K8s/Podman secrets.
COPY --chown=node:node containerfiles/opencode.json /workspace/opencode.json

# Entrypoint: configures git credentials at startup if GITHUB_PAT is set
USER root
COPY --chmod=755 containerfiles/entrypoint.sh /usr/local/bin/entrypoint.sh
USER node

# ---- Golang variant ----
FROM base-common AS lang-golang
USER root
RUN apt-get update && apt-get install -y --no-install-recommends golang-go \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
USER node

# ---- Python variant ----
FROM base-common AS lang-python
USER root
RUN apt-get update && apt-get install -y --no-install-recommends python3-pip python3-venv \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
USER node

# ---- Final stage (selected by LANG build arg) ----
FROM lang-${LANG} AS final

# GCP credentials path for Claude via Vertex AI — value injected at runtime
ENV GOOGLE_APPLICATION_CREDENTIALS=/app/gcloud/credentials.json

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["opencode"]
