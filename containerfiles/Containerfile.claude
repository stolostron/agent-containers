ARG LANG=golang

# ---- Base: node + git + claude-code ----
FROM node:20-slim AS base-common

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates zsh fzf vim nano less jq ripgrep \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# npm global prefix under /usr/local/share, owned by the non-root "node" user
# (the "node" user already exists in the base image)
RUN mkdir -p /usr/local/share/npm-global \
    && chown -R node:node /usr/local/share/npm-global
ENV NPM_CONFIG_PREFIX=/usr/local/share/npm-global
ENV PATH=$PATH:/usr/local/share/npm-global/bin

USER node
RUN npm install -g @anthropic-ai/claude-code && npm cache clean --force
WORKDIR /workspace

ENV DEVCONTAINER=true
ENV EDITOR=nano
ENV NODE_OPTIONS=--max-old-space-size=4096

# ---- Golang variant ----
FROM base-common AS lang-golang
USER root
RUN apt-get update && apt-get install -y --no-install-recommends golang-go \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
USER node

# ---- Python variant ----
FROM base-common AS lang-python
USER root
RUN apt-get update && apt-get install -y --no-install-recommends python3-pip python3-venv \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
USER node

# ---- Final stage (selected by LANG build arg) ----
FROM lang-${LANG} AS final

# Vertex AI — values injected at runtime via K8s/Podman secrets
ENV CLAUDE_CODE_USE_VERTEX=1
ENV GOOGLE_APPLICATION_CREDENTIALS=/app/gcloud/credentials.json

CMD ["claude", "--dangerously-skip-permissions"]
